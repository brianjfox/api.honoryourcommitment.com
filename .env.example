# ------------------------------------------------------------------
# API server configuration. Copy to `.env` and fill in.
# ------------------------------------------------------------------

NODE_ENV=development

# Where the API listens. Bind to localhost in production so only Nginx
# (the reverse proxy on the same box) can reach it.
HOST=127.0.0.1
PORT=3000

# Postgres connection. In production, run Postgres on the same box and
# keep it bound to localhost (never exposed to the internet).
DATABASE_URL=postgres://phyc:phyc@localhost:5432/phyc

# Public origin of the frontend (used for CORS + post-confirmation redirect).
FRONTEND_URL=http://localhost:5173

# Public base URL of THIS api (used to build confirmation links in emails).
API_PUBLIC_URL=http://localhost:3000

# The privacy-policy version recorded against each consent (for audit).
PRIVACY_POLICY_VERSION=2026-06-12

# Salt used to hash visitor IPs before storage (abuse detection without
# storing raw IPs). Generate a long random value: `openssl rand -hex 32`.
IP_HASH_SALT=change-me-to-a-long-random-string

# --- Cloudflare Turnstile ---
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=
# Set true in local dev to skip Turnstile verification entirely.
DISABLE_TURNSTILE=true

# --- Email (plain SMTP) ---
# Leave DISABLE_EMAIL=true until you plug in real SMTP credentials; the
# confirmation link is logged to the console instead of being emailed.
DISABLE_EMAIL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Honor Your Commitment <no-reply@honoryourcommitment.com>"

# --- Rate limiting (per IP) ---
# Global cap across all routes, and a tighter cap on write/submit routes.
RATE_LIMIT_GLOBAL_MAX=120
RATE_LIMIT_GLOBAL_WINDOW=1 minute
RATE_LIMIT_SUBMIT_MAX=5
RATE_LIMIT_SUBMIT_WINDOW=10 minutes
