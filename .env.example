# ------------------------------------------------------------------
# API server configuration. Copy to `.env` and fill in.
# ------------------------------------------------------------------

NODE_ENV=development

# Where the API listens. Bind to localhost in production so only Nginx
# (the reverse proxy on the same box) can reach it.
HOST=127.0.0.1
PORT=3000

# Postgres connection. In production, run Postgres on the same box and
# keep it bound to localhost (never exposed to the internet).
DATABASE_URL=postgres://phyc:phyc@localhost:5432/phyc

# Public origin of the frontend (used for CORS + post-confirmation redirect).
FRONTEND_URL=http://localhost:5173

# Public base URL of THIS api (used to build confirmation links in emails).
API_PUBLIC_URL=http://localhost:3000

# The privacy-policy version recorded against each consent (for audit).
PRIVACY_POLICY_VERSION=2026-06-12

# Salt used to hash visitor IPs before storage (abuse detection without
# storing raw IPs). Generate a long random value: `openssl rand -hex 32`.
IP_HASH_SALT=change-me-to-a-long-random-string

# --- Cloudflare Turnstile ---
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=
# Set true in local dev to skip Turnstile verification entirely.
DISABLE_TURNSTILE=true

# --- Email (plain SMTP — any provider) ---
# Prefer an EU transactional provider for data residency + deliverability, e.g.
#   Scaleway TEM : SMTP_HOST=smtp.tem.scaleway.com  SMTP_PORT=587
#   Mailjet      : SMTP_HOST=in-v3.mailjet.com       SMTP_PORT=587
#   Brevo        : SMTP_HOST=smtp-relay.brevo.com    SMTP_PORT=587
# SMTP_USER/SMTP_PASS are the provider's SMTP credentials (often API keys).
# Verify before going live:  npm run test-email you@example.com
# Leave DISABLE_EMAIL=true until verified; the confirmation link is logged then.
DISABLE_EMAIL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Use a From address on a domain you've authenticated (SPF/DKIM) at the provider.
EMAIL_FROM="Honor Your Commitment <no-reply@honoryourcommitment.com>"
# Optional: where replies go (the From above is unmonitored / no-reply).
EMAIL_REPLY_TO=

# --- Daily news curation (scripts/fetch-news.js, run by a systemd timer) ---
# Uses Claude + web search to find recent articles. Leave ANTHROPIC_API_KEY
# blank to disable the feature (the fetch script no-ops). Default model is
# claude-opus-4-8; override with a cheaper model for lower cost if desired.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
NEWS_COUNT=4
NEWS_LOOKBACK_DAYS=21

# --- Rate limiting (per IP) ---
# Global cap across all routes, and a tighter cap on write/submit routes.
RATE_LIMIT_GLOBAL_MAX=120
RATE_LIMIT_GLOBAL_WINDOW=1 minute
RATE_LIMIT_SUBMIT_MAX=5
RATE_LIMIT_SUBMIT_WINDOW=10 minutes
